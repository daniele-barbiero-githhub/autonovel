# LLM provider: anthropic (default) or gemini
AUTONOVEL_LLM_PROVIDER=anthropic

# Optional per-role provider overrides
# AUTONOVEL_WRITER_PROVIDER=gemini
# AUTONOVEL_JUDGE_PROVIDER=anthropic
# AUTONOVEL_REVIEW_PROVIDER=gemini

# Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# Gemini API key
GEMINI_API_KEY=your-gemini-api-key-here

# Writer model (used for drafting and revision)
AUTONOVEL_WRITER_MODEL=claude-sonnet-4-6

# Judge model (used for evaluation — should differ from writer)
AUTONOVEL_JUDGE_MODEL=claude-sonnet-4-6

# Review model (Opus — deep prose-level analysis, used in Phase 3b)
AUTONOVEL_REVIEW_MODEL=claude-opus-4-6

# Provider-specific model overrides are useful if you switch providers without
# changing the generic model lines above.
# AUTONOVEL_GEMINI_WRITER_MODEL=gemini-2.5-pro
# AUTONOVEL_GEMINI_JUDGE_MODEL=gemini-2.5-pro
# AUTONOVEL_GEMINI_REVIEW_MODEL=gemini-2.5-pro

# API base URLs
AUTONOVEL_API_BASE_URL=https://api.anthropic.com
# AUTONOVEL_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# fal.ai key for image generation (Nano Banana 2)
FAL_KEY=your-fal-api-key-here

# ElevenLabs API key for audiobook generation
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here
